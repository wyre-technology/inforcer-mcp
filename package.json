{
  "name": "inforcer-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Inforcer Microsoft 365 baseline governance platform",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "inforcer-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "inforcer",
    "mcp",
    "msp",
    "microsoft-365",
    "governance",
    "baseline",
    "model-context-protocol"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@wyre-technology/node-inforcer": "^1.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^26.1.1",
    "semantic-release": "^25.0.8",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
